{
  "name": "potato-ssr",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "dev": "npm run css && tsx watch --tsconfig tsconfig.json src/server.ts",
    "start": "npm run css && tsx --tsconfig tsconfig.json src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "potato-train-core": "^0.2.0",
    "potato-train-jsx": "^0.2.0",
    "potato-train-live": "^0.2.0",
    "potato-train-ssr": "^0.2.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.0",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  },
  "trustedDependencies": ["@parcel/watcher", "esbuild"]
}
