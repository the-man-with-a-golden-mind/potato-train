{
  "name": "potato-train-vite-plugin",
  "version": "0.2.0",
  "description": "Official Vite plugin for Potato (JSX, aliases, dev defaults)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node -e \"const fs=require('fs');if(!fs.existsSync('dist')){console.error('dist/ missing — run pnpm build first');process.exit(1)}\"",
    "test": "node ../../scripts/test-package.mjs"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  },
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
