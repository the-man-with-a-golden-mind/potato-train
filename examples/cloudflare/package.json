{
  "name": "potato-train-example-cloudflare",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Optional example — not in default workspace (wrangler is heavy). From monorepo root: pnpm --filter potato-train-example-cloudflare… only after linking; or cd here && pnpm install",
  "scripts": {
    "css": "node scripts/build-css.mjs",
    "dev": "pnpm css && wrangler dev src/worker.tsx",
    "deploy": "pnpm css && wrangler deploy src/worker.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "potato-train-cloudflare": "workspace:*",
    "potato-train-core": "workspace:*",
    "potato-train-db": "workspace:*",
    "potato-train-jsx": "workspace:*",
    "potato-train-live": "workspace:*",
    "potato-train-ssr": "workspace:*",
    "drizzle-orm": "^0.40.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.2",
    "wrangler": "^4.0.0"
  }
}
